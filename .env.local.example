# Copy to .env.local and fill in to enable Supabase (email auth + server-side
# C++ judge proxy). ALL OPTIONAL — the app runs fully without these:
#   - Auth falls back to guest mode.
#   - C++ judging calls the Compiler Explorer API directly from the browser.
#
# Get these from the Supabase dashboard: Settings -> API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...
