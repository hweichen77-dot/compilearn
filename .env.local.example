# Copy to .env.local and fill in to enable Supabase (email auth + server-side
# C++ judge proxy). ALL OPTIONAL — the app runs fully without these:
#   - Auth falls back to guest mode.
#   - C++ judging calls the Compiler Explorer API directly from the browser.
#
# Get these from the Supabase dashboard: Settings -> API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Public base URL of the deployed site, with no trailing slash. Canonical
# links, Open Graph tags, the sitemap, and share links are all built from it.
# Leave unset in development and the app falls back to the current origin.
# When a custom domain is ready, set this to https://yourdomain.com and
# redeploy. That is the only change needed.
VITE_SITE_URL=https://compilearn.vercel.app
