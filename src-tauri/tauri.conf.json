{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Compilearn",
  "version": "2.11.0",
  "identifier": "com.compilearn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "title": "Compilearn",
        "width": 1280,
        "height": 832,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://*.supabase.co https://godbolt.org https://us.i.posthog.com https://*.posthog.com https://*.sentry.io https://*.ingest.sentry.io https://stream.mux.com https://*.mux.com; media-src 'self' blob: https://stream.mux.com https://*.mux.com; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "codeflow"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc4Q0MyRUNEQ0JBMzgzOEUKUldTT2c2UEx6UzdNZUsrb2RvR01Ec3NYZkNrcDhvOXplSnAvOTQrL3ZYTEQ3NUtvME9mQTRycysK",
      "endpoints": [
        "https://github.com/hweichen77-dot/compilearn/releases/latest/download/latest.json"
      ]
    }
  }
}
